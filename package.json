{
    "name": "access-explorer",
    "displayName": "%extension.displayName%",
    "description": "%extension.description%",
    "version": "1.0.20",
    "publisher": "luna-soft",
    "author": {
        "name": "Juanjo Luna",
        "email": "juanjo@luna-soft.es",
        "url": "https://blog.luna-soft.es/"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/lunasoft2001/vscode-access.git"
    },
    "homepage": "https://github.com/lunasoft2001/vscode-access#readme",
    "icon": "media/accessexplorer2.png",
    "license": "SEE LICENSE IN LICENSE",
    "engines": {
        "vscode": "^1.92.0"
    },
    "categories": [
        "Programming Languages",
        "Other"
    ],
    "activationEvents": [
        "onView:accessExplorerView",
        "onCommand:accessExplorer.addConnection",
        "onCommand:accessExplorer.removeConnection",
        "onCommand:accessExplorer.refresh",
        "onCommand:accessExplorer.reconnect",
        "onCommand:accessExplorer.showMcpRuntime",
        "onCommand:accessExplorer.restartAccessProcesses",
        "onCommand:accessExplorer.registerMcpServer",
        "onCommand:accessExplorer.searchObjects",
        "onCommand:accessExplorer.showDetails",
        "onCommand:accessExplorer.runSqlQuery",
        "onCommand:accessExplorer.executeActiveSql",
        "onCommand:accessExplorer.openSqlEditor",
        "onCommand:accessExplorer.pickSqlConnection",
        "onCommand:accessExplorer.saveCodeToAccess",
        "onCommand:accessExplorer.compileVba",
        "onCommand:accessExplorer.compactRepair",
        "onCommand:accessExplorer.secondBrain.full",
        "onCommand:accessExplorer.secondBrain.category",
        "onCommand:accessExplorer.secondBrain.object",
        "onCommand:accessExplorer.exportObjects.full",
        "onCommand:accessExplorer.exportObjects.category"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "accessExplorer",
                    "title": "%viewsContainer.title%",
                    "icon": "media/accessexplorerv5.svg"
                }
            ]
        },
        "views": {
            "accessExplorer": [
                {
                    "id": "accessExplorerView",
                    "name": "%view.databases.name%",
                    "icon": "media/accessexplorerv5.svg"
                }
            ]
        },
        "commands": [
            {
                "command": "accessExplorer.addConnection",
                "title": "%command.addConnection.title%",
                "icon": "$(add)"
            },
            {
                "command": "accessExplorer.removeConnection",
                "title": "%command.removeConnection.title%",
                "icon": "$(trash)"
            },
            {
                "command": "accessExplorer.refresh",
                "title": "%command.refresh.title%",
                "icon": "$(refresh)"
            },
            {
                "command": "accessExplorer.reconnect",
                "title": "%command.reconnect.title%",
                "icon": "$(debug-restart)"
            },
            {
                "command": "accessExplorer.restartAccessProcesses",
                "title": "%command.restartProcesses.title%",
                "icon": "$(debug-disconnect)"
            },
            {
                "command": "accessExplorer.showMcpRuntime",
                "title": "%command.showMcpRuntime.title%",
                "icon": "$(server-process)"
            },
            {
                "command": "accessExplorer.registerMcpServer",
                "title": "%command.registerMcpServer.title%",
                "icon": "$(plug)"
            },
            {
                "command": "accessExplorer.searchObjects",
                "title": "%command.searchObjects.title%",
                "icon": "$(search)"
            },
            {
                "command": "accessExplorer.showDetails",
                "title": "%command.showDetails.title%"
            },
            {
                "command": "accessExplorer.runSqlQuery",
                "title": "%command.runSqlQuery.title%",
                "icon": "$(play)"
            },
            {
                "command": "accessExplorer.executeActiveSql",
                "title": "%command.executeActiveSql.title%",
                "icon": "$(run-all)"
            },
            {
                "command": "accessExplorer.openSqlEditor",
                "title": "%command.openSqlEditor.title%",
                "icon": "$(new-file)"
            },
            {
                "command": "accessExplorer.pickSqlConnection",
                "title": "%command.pickSqlConnection.title%",
                "icon": "$(database)"
            },
            {
                "command": "accessExplorer.saveCodeToAccess",
                "title": "%command.saveCodeToAccess.title%",
                "icon": "$(cloud-upload)"
            },
            {
                "command": "accessExplorer.compileVba",
                "title": "%command.compileVba.title%",
                "icon": "$(check)"
            },
            {
                "command": "accessExplorer.compactRepair",
                "title": "%command.compactRepair.title%",
                "icon": "$(wrench)"
            },
            {
                "command": "accessExplorer.secondBrain.full",
                "title": "%command.secondBrainFull.title%",
                "icon": "$(book)"
            },
            {
                "command": "accessExplorer.secondBrain.category",
                "title": "%command.secondBrainCategory.title%",
                "icon": "$(list-tree)"
            },
            {
                "command": "accessExplorer.secondBrain.object",
                "title": "%command.secondBrainObject.title%",
                "icon": "$(symbol-object)"
            },
            {
                "command": "accessExplorer.exportObjects.full",
                "title": "%command.exportObjectsFull.title%",
                "icon": "$(export)"
            },
            {
                "command": "accessExplorer.exportObjects.category",
                "title": "%command.exportObjectsCategory.title%",
                "icon": "$(export)"
            }
        ],
        "menus": {
            "view/title": [
                {
                    "command": "accessExplorer.addConnection",
                    "when": "view == accessExplorerView",
                    "group": "navigation@1"
                },
                {
                    "command": "accessExplorer.refresh",
                    "when": "view == accessExplorerView",
                    "group": "navigation@2"
                },
                {
                    "command": "accessExplorer.restartAccessProcesses",
                    "when": "view == accessExplorerView",
                    "group": "navigation@3"
                },
                {
                    "command": "accessExplorer.searchObjects",
                    "when": "view == accessExplorerView",
                    "group": "navigation@4"
                },
                {
                    "command": "accessExplorer.showMcpRuntime",
                    "when": "view == accessExplorerView",
                    "group": "navigation@5"
                },
                {
                    "command": "accessExplorer.runSqlQuery",
                    "when": "view == accessExplorerView",
                    "group": "navigation@6"
                },
                {
                    "command": "accessExplorer.openSqlEditor",
                    "when": "view == accessExplorerView",
                    "group": "navigation@7"
                },
                {
                    "command": "accessExplorer.secondBrain.full",
                    "when": "view == accessExplorerView",
                    "group": "navigation@8"
                }
            ],
            "editor/title": [
                {
                    "command": "accessExplorer.executeActiveSql",
                    "when": "editorLangId == sql",
                    "group": "navigation@1"
                },
                {
                    "command": "accessExplorer.pickSqlConnection",
                    "when": "editorLangId == sql",
                    "group": "navigation@2"
                },
                {
                    "command": "accessExplorer.saveCodeToAccess",
                    "when": "editorLangId == vb",
                    "group": "navigation@1"
                }
            ],
            "view/item/context": [
                {
                    "command": "accessExplorer.refresh",
                    "when": "view == accessExplorerView && viewItem == accessConnection",
                    "group": "inline"
                },
                {
                    "command": "accessExplorer.reconnect",
                    "when": "view == accessExplorerView && viewItem == accessConnection",
                    "group": "inline"
                },
                {
                    "command": "accessExplorer.removeConnection",
                    "when": "view == accessExplorerView && viewItem == accessConnection"
                },
                {
                    "command": "accessExplorer.compileVba",
                    "when": "view == accessExplorerView && viewItem == accessConnection",
                    "group": "1_actions@1"
                },
                {
                    "command": "accessExplorer.compactRepair",
                    "when": "view == accessExplorerView && viewItem == accessConnection",
                    "group": "1_actions@2"
                },
                {
                    "command": "accessExplorer.secondBrain.full",
                    "when": "view == accessExplorerView && viewItem == accessConnection",
                    "group": "1_actions@3"
                },
                {
                    "command": "accessExplorer.secondBrain.category",
                    "when": "view == accessExplorerView && viewItem == accessCategory",
                    "group": "2_actions@1"
                },
                {
                    "command": "accessExplorer.showDetails",
                    "when": "view == accessExplorerView && viewItem == accessObject"
                },
                {
                    "command": "accessExplorer.secondBrain.object",
                    "when": "view == accessExplorerView && viewItem == accessObject",
                    "group": "2_actions@2"
                }
            ]
        },
        "configuration": {
            "title": "%configuration.title%",
            "properties": {
                "accessExplorer.mcp.pythonCommand": {
                    "type": "string",
                    "default": "python",
                    "description": "%config.pythonCommand.description%"
                },
                "accessExplorer.mcp.serverScriptPath": {
                    "type": "string",
                    "default": "",
                    "description": "%config.serverScriptPath.description%"
                },
                "accessExplorer.mcp.toolPrefix": {
                    "type": "string",
                    "default": "access",
                    "description": "%config.toolPrefix.description%"
                },
                "accessExplorer.mcp.requestTimeoutMs": {
                    "type": "number",
                    "default": 30000,
                    "minimum": 1000,
                    "description": "%config.requestTimeoutMs.description%"
                },
                "accessExplorer.mcp.sqlQueryTimeoutMs": {
                    "type": "number",
                    "default": 600000,
                    "minimum": 5000,
                    "description": "%config.sqlQueryTimeoutMs.description%"
                },
                "accessExplorer.mcp.autoEnableVbaTrust": {
                    "type": "boolean",
                    "default": false,
                    "description": "%config.autoEnableVbaTrust.description%"
                },
                "accessExplorer.mcp.preserveTrustedLocations": {
                    "type": "boolean",
                    "default": true,
                    "description": "%config.preserveTrustedLocations.description%"
                }
            }
        }
    },
    "scripts": {
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "vscode:prepublish": "npm run compile"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.29.0"
    },
    "devDependencies": {
        "@types/node": "^20.14.8",
        "@types/vscode": "^1.92.0",
        "typescript": "^5.5.4"
    }
}
